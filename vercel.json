{
	"version": 2,
	"experimentalServices": {
		"frontend": {
			"entrypoint": "frontend",
			"routePrefix": "/",
			"framework": "create-react-app"
		},
		"backend": {
			"entrypoint": "backend",
			"routePrefix": "/_/backend"
		}
	},
	"builds": [
		{
			"src": "frontend/package.json",
			"use": "@vercel/static-build",
			"config": {
				"distDir": "build"
			}
		}
	],
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "/(.*)",
			"dest": "/index.html"
		}
	]
}