PORT=5000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/hospital_management
JWT_SECRET=replace_with_a_strong_secret

# Comma-separated list of allowed frontend origins.
# Example (local + Vercel): http://localhost:3000,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# Set to true if your hosted Postgres requires SSL (common on Render/Neon).
DATABASE_SSL=false
