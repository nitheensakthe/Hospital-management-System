# Frontend talks to the backend API.
# For local dev (backend on http://localhost:5000):
# REACT_APP_API_BASE_URL=http://localhost:5000/api
#
# For production (backend on Render):
# You can set either:
# REACT_APP_API_BASE_URL=https://<your-render-service>.onrender.com
# or:
# REACT_APP_API_BASE_URL=https://<your-render-service>.onrender.com/api
REACT_APP_API_BASE_URL=http://localhost:5000/api
